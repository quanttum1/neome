datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client"
  output   = "../src/generated/"
}

model User {
  id           Int    @id @default(autoincrement())
  username     String @unique
  passwordHash String
  token        String @unique
  events       Event[]
}

model Event {
  id       String   @id @db.Uuid
  data     Json

  time     DateTime
  pushTime DateTime @default(now())

  userId   Int
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@index([userId, pushTime])
  @@index([userId, time])
}
